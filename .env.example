# Supabase — Project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (recommended) — starts with sb_publishable_
# Dashboard → Settings → API Keys → Create publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy anon JWT key (optional fallback during migration)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Drizzle ORM — Supabase Postgres connection string (Settings → Database → URI)
# Use the "Transaction" pooler URL for serverless (port 6543)
DATABASE_URL=

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: public MCP HTTP endpoint shown in /docs (e.g. https://your-domain/mcp)
# NEXT_PUBLIC_MCP_URL=

# Secret key (recommended, server-only) — starts with sb_secret_
# Dashboard → Settings → API Keys → Create secret key
# Never expose in the browser or NEXT_PUBLIC_ vars
SUPABASE_SECRET_KEY=

# Legacy service_role JWT key (optional fallback for seed script / migration)
# SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini — in-app AI assistant (server-only)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional: separate secret for destructive-action confirmation tokens
# AI_CONFIRMATION_SECRET=

# Gmail SMTP — transactional email (verification, friend requests, contact form)
# Create an App Password: Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=connect.jawadasghar@gmail.com
SMTP_PASS=
# Optional display name; defaults to Finance Buddy <SMTP_USER>
# EMAIL_FROM=Finance Buddy <connect.jawadasghar@gmail.com>
# Inbox for /contact form submissions
CONTACT_INBOX_EMAIL=connect.jawadasghar@gmail.com

# ExchangeRate-API — live currency conversion (server-only)
# Get a key at https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=
# Optional: override the full API URL (takes precedence over EXCHANGE_RATE_API_KEY)
# EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6/YOUR-API-KEY/latest/USD

